<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue"
    android:padding="@dimen/padding_default">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_top_title"
        android:text="@string/app_title"
        android:textColor="@color/white"
        android:textSize="@dimen/text_size_title"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/menuContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_top_container"
        android:layout_weight="1"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <Button
            android:id="@+id/btnSearch"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="@dimen/margin_bottom_card"
            android:layout_weight="1"
            android:backgroundTint="@android:color/white"
            android:drawablePadding="@dimen/margin_end_icon"
            android:gravity="center"
            android:padding="@dimen/card_padding"
            android:text="@string/search"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_card"
            app:cornerRadius="@dimen/button_corner_radius"
            app:icon="@drawable/search"
            app:iconGravity="textStart"
            app:iconTint="@color/black"/>

        <Button
            android:id="@+id/btnMedia"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="@dimen/margin_bottom_card"
            android:layout_weight="1"
            android:backgroundTint="@android:color/white"
            android:drawablePadding="@dimen/margin_end_icon"
            android:gravity="center"
            android:padding="@dimen/card_padding"
            android:stateListAnimator="@null"
            android:text="@string/media_library"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_card"
            app:icon="@drawable/media"
            app:iconGravity="textStart"
            app:iconTint="@color/black"
            app:cornerRadius="@dimen/button_corner_radius" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="@dimen/margin_bottom_card"
            android:layout_weight="1"
            android:backgroundTint="@android:color/white"
            android:drawablePadding="@dimen/margin_end_icon"
            android:gravity="center"
            android:padding="@dimen/card_padding"
            android:text="@string/settings"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_card"
            app:icon="@drawable/settings"
            app:iconGravity="textStart"
            app:iconTint="@color/black"
            app:cornerRadius="@dimen/button_corner_radius" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>